# ===== WZÓR zmiennych środowiskowych =====
# To NIE jest prawdziwy plik konfiguracji — to wzór.
# Realne wartości wpisuje się w panelu Vercel: Project → Settings → Environment Variables.
# Plik .env (realny) NIGDY nie trafia do repo (jest w .gitignore).

# ----- SMTP (formularz kontaktowy z index.html) -----
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=info@example.com
SMTP_PASS=tutaj-twoje-haslo-smtp
SMTP_FROM=info@example.com
SMTP_FROM_NAME=AllesKlar IT Service
SMTP_TO=odbiorca@example.com

# ----- Anthropic Claude API (kalkulator AI — komentarz po polsku) -----
# Wypełnić gdy zaczniemy podpinać kalkulator do API
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx

# ----- Stripe (płatność 4,99€ za odblokowanie wyniku) -----
# Wypełnić gdy zaczniemy podpinać płatności
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
